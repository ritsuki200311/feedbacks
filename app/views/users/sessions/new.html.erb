<div class="flex items-center justify-center min-h-screen py-6">
  <div class="w-full max-w-md px-4">
    <div class="bg-white shadow-md rounded px-8 pt-6 pb-8">
      <h2 class="text-2xl font-bold mb-6 text-center">ログイン</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <div>
          <%= f.label :name, "ユーザー名", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, autofocus: true, required: true, class: "mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          <p class="text-xs text-gray-500 mt-1">ユーザー名を入力してください</p>
        </div>

        <div>
          <%= f.submit "ログイン", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-md" %>
        </div>
      <% end %>

      <div class="mt-6 text-center">
        <%= render "users/shared/links" %>
      </div>
    </div>
  </div>
</div>