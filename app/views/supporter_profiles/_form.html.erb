<%= form_with(model: @supporter_profile, url: supporter_profile_path(@supporter_profile), local: true, class: "space-y-8 bg-white p-8 rounded-lg shadow-md") do |f| %>
  <% if @supporter_profile.errors.any? %>
    <div class="bg-red-100 text-red-700 p-4 rounded mb-6">
      <p class="font-bold">入力エラーがあります：</p>
      <ul class="list-disc pl-5">
        <% @supporter_profile.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label class="block text-lg font-semibold text-gray-800 mb-3">年齢を入力してください</label>
    <%= f.number_field :age_group, min: 1, max: 120, placeholder: "例: 25", class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", required: true %>
  </div>

  <%# 実際に創作をしていますか %>
  <div>
    <label class="block text-lg font-semibold text-gray-800 mb-3">実際に創作をしていますか（またはしていましたか？）</label>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <% ['イラスト・絵画', 'マンガ', '小説・詩・エッセイ', '音楽制作・作詞作曲', '映像制作・動画編集', 'デザイン・グラフィック', '写真・撮影技術', 'その他', 'していない'].each do |option| %>
        <label class="flex items-center p-3 rounded-lg border cursor-pointer transition-colors hover:bg-gray-50">
          <%= check_box_tag "supporter_profile[support_genres][]", option, @supporter_profile.support_genres.include?(option), class: "h-5 w-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500", onchange: "toggleOtherInputForm('support_genres_other_form', this, 'その他')" %>
          <span class="ml-3 text-gray-700"><%= option %></span>
        </label>
      <% end %>
    </div>
    <!-- その他の入力欄 -->
    <div id="support_genres_other_form" class="mt-4" style="display: none;">
      <label class="block text-sm font-medium text-gray-700 mb-2">その他の詳細を入力してください</label>
      <%= f.text_field :support_genres_other_text, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "例：陶芸、編み物、プログラミングなど" %>
    </div>
  </div>

  <div>
    <label class="block text-lg font-semibold text-gray-800 mb-3">創作経験を入力してください</label>
    <%= f.select :creation_experience, ['1年未満', '1-3年', '4-6年', '7-10年', '10年以上', '経験なし'], { prompt: "選択してください" }, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <%# 精通してるジャンルの質問 %>
  <div>
    <label class="block text-lg font-semibold text-gray-800 mb-3">よく見るジャンルはありますか？</label>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <% ['イラスト・絵画', 'マンガ', '小説・詩・エッセイ', '音楽制作・作詞作曲', '映像制作・動画編集', 'デザイン・グラフィック', '写真・撮影技術', 'その他'].each do |option| %>
        <label class="flex items-center p-3 rounded-lg border cursor-pointer transition-colors hover:bg-gray-50">
          <%= check_box_tag "supporter_profile[interests][]", option, @supporter_profile.interests.include?(option), class: "h-5 w-5 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500", onchange: "toggleOtherInputForm('interests_other_form', this, 'その他')" %>
          <span class="ml-3 text-gray-700"><%= option %></span>
        </label>
      <% end %>
    </div>
    <!-- その他の入力欄 -->
    <div id="interests_other_form" class="mt-4" style="display: none;">
      <label class="block text-sm font-medium text-gray-700 mb-2">その他の詳細を入力してください</label>
      <%= f.text_field :interests_other_text, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "例：ゲーム、舞台、手芸など" %>
    </div>
  </div>

  <div>
    <label class="block text-lg font-semibold text-gray-800 mb-3">実際に好きなアーティストや作品を教えてください</label>
    <%= f.text_area :favorite_works, rows: 4, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "例：宮崎駿、新海誠、ピクサー作品、米津玄師、ヨルシカ、東野圭吾の小説、ONE PIECEなど..." %>
  </div>

  <%# SelectとTextAreaのセクション %>
  <div>
    <label class="block text-lg font-semibold text-gray-800 mb-3">フィードバックできそうなことを教えてください</label>
    <p class="text-sm text-gray-600 mb-3">※ここに書いた内容に関するコメント依頼が届く可能性があります（回答しない場合はスキップ可能）</p>
    <%= f.text_area :favorite_artists, rows: 4, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500", placeholder: "例：デジタルイラストのレイヤー構成、小説の三人称視点の書き方、DTMでのミックス技法、動画編集のカット割り、写真の構図理論など...具体的なスキルや知識を教えてください" %>
  </div>

  <!-- 保存ボタン -->
  <div class="pt-6 text-center">
    <%= f.submit "プロフィールを保存する", class: "w-full md:w-auto bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-lg font-bold text-lg shadow-md transition-transform transform hover:scale-105" %>
  </div>
<% end %>

<style>
  input[type="number"]::placeholder,
  textarea::placeholder {
    color: #d1d5db;
    opacity: 0.6;
  }
</style>

<script>
  function toggleOtherInputForm(elementId, checkbox, targetValue) {
    const otherDiv = document.getElementById(elementId);
    if (checkbox.value === targetValue && checkbox.checked) {
      otherDiv.style.display = 'block';
    } else if (checkbox.value === targetValue && !checkbox.checked) {
      otherDiv.style.display = 'none';
    }
  }

  // ページロード時に「その他」がチェックされていれば入力欄を表示
  document.addEventListener('DOMContentLoaded', function() {
    const supportGenresCheckboxes = document.querySelectorAll('input[name="supporter_profile[support_genres][]"]');
    supportGenresCheckboxes.forEach(function(checkbox) {
      if (checkbox.value === 'その他' && checkbox.checked) {
        document.getElementById('support_genres_other_form').style.display = 'block';
      }
    });

    const interestsCheckboxes = document.querySelectorAll('input[name="supporter_profile[interests][]"]');
    interestsCheckboxes.forEach(function(checkbox) {
      if (checkbox.value === 'その他' && checkbox.checked) {
        document.getElementById('interests_other_form').style.display = 'block';
      }
    });
  });
</script>